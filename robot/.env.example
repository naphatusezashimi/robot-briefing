# คัดลอกไฟล์นี้เป็น .env แล้วใส่ key จริง

# ใช้เมื่อ AI_PROVIDER = "gemini" (ฟรี) — ขอ key ที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# ใช้เมื่อ AI_PROVIDER = "claude" — ขอ key ที่ https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# เฟส 2: path ไปยัง service account JSON ของ Google Cloud
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
